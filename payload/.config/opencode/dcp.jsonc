{
  // Enable or disable the plugin
  "enabled": true,
  // Enable debug logging (logs written to the opencode config logs/dcp/ directory)
  "debug": false,
  // Override model for analysis (format: "provider/model", e.g. "anthropic/claude-haiku-4-5")
  // "model": "anthropic/claude-haiku-4-5",
  // Show toast notifications when model selection fails
  "showModelErrorToasts": true,
  // Show toast notifications when a new version is available
  "showUpdateToasts": true,
  // Only run AI analysis with session model or configured model (disables fallback models)
  "strictModelSelection": false,
  // Continuous analyzer lane (deduplication still runs automatically on every request)
  "strategies": {
    // Primary background analyzer
    "onIdle": ["ai-analysis"],
    // Fallback analyzer when tool-heavy sessions need cleanup support
    "onTool": ["ai-analysis"]
  },
  // Summary display: "off", "minimal", or "detailed"
  "pruning_summary": "minimal",
  // How often to nudge the AI to prune (every N tool results, 0 = disabled)
  "nudge_freq": 8
  // Additional tools to protect from pruning
  // "protectedTools": ["bash"]
}
